# ============================================
# OpenAI / DeepSeek 配置
# ============================================

# API 地址（默认 https://api.openai.com/v1）
# 使用 DeepSeek：https://api.deepseek.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# API 密钥（必填，启动前请替换为真实 key）
OPENAI_API_KEY=sk-your-api-key-here

# 模型名称，默认 deepseek-r1-distill-qwen-1.5b
OPENAI_MODEL=deepseek-r1-distill-qwen-1.5b

# 请求超时（毫秒），默认 60000
OPENAI_TIMEOUT_MS=60000

# 温度参数 0-2，默认 0.7
OPENAI_TEMP=0.7

# 最大输出 token 数，默认 1024
OPENAI_MAX_TOKENS=1024

# ============================================
# 调试配置
# ============================================

# 开启后会在控制台打印 chat 请求的调试日志
DEBUG_CHAT=false

# Node 环境：development | production
NODE_ENV=development
